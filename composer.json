{
    "name": "raparty/inventory-agent",
    "description": "Enterprise Inventory Management System",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "ext-mysqli": "*",
        "ext-json": "*",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^11.5.50"
    },
    "autoload": {
        "psr-4": {
            "InventoryAgent\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "InventoryAgent\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "analyse": "vendor/bin/phpstan analyse --level=5",
        "lint": "find . -path ./vendor -prune -o -name '*.php' -print | xargs -I{} php -l {}"
    },
    "license": "proprietary",
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
