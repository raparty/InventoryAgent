# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real credentials.

DB_HOST=localhost
DB_USER=your_database_user
DB_PASS=your_database_password
DB_NAME=inventory_database

TEAMS_WEBHOOK_URL=your_teams_webhook_url_here

APP_NAME="Enterprise Inventory"
APP_ENV=production

# Operational thresholds (days) — override only if your environment requires different values
OFFLINE_DAYS_THRESHOLD=7
PATCH_COMPLIANCE_DAYS=45
PATCH_GRACE_DAYS=14
PATCH_RECENT_DAYS=30
